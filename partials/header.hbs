{{!--
This header template is shared across all the pages.
--}}

<header class="m-header {{#if background}}with-picture{{/if}} js-header"  data-animate="fade-down">
  <div class="m-mobile-topbar">
    <button class="m-icon-button in-mobile-topbar js-open-menu" aria-label="Open menu">
      <span class="icon-menu" aria-hidden="true"></span>
    </button>
    {{#if @root.site.logo}}
      <a href="{{@root.site.url}}" class="m-logo in-mobile-topbar">
        <img src="{{@root.site.logo}}" alt="{{@root.site.title}}" class="{{#if @root.custom.dark_mode_logo}}m-logo__image-light{{/if}}">
        {{#if @root.custom.dark_mode_logo}}
          <img src="{{@root.custom.dark_mode_logo}}" alt="{{@root.site.title}}" class="m-logo__image-dark">
        {{/if}}
      </a>
    {{else}}
      <a href="{{@root.site.url}}" class="m-site-name in-mobile-topbar">
        {{@root.site.title}}
      </a>
    {{/if}}
    <button class="m-icon-button in-mobile-topbar {{#if @root.custom.enable_native_search}}js-open-search{{/if}}" {{#if @root.custom.enable_native_search}}data-ghost-search{{/if}} aria-label="Open search">
      <span class="icon-search" aria-hidden="true"></span>
    </button>
  </div>

  <div class="m-menu js-menu">
    <button class="m-icon-button outlined as-close-menu js-close-menu" aria-label="Close menu">
      <span class="icon-close"></span>
    </button>
    <div class="m-menu__main">
      <div class="l-wrapper">
        <div class="m-nav js-main-nav" style="overflow: visible;">
          <nav class="m-nav__left js-main-nav-left" role="navigation" aria-label="Main menu">
            <ul>
              {{#if @root.site.logo}}
                <li class="only-desktop">
                  <a href="{{@root.site.url}}" class="m-logo">
                    <img src="{{@root.site.logo}}" alt="{{@root.site.title}}" class="{{#if @root.custom.dark_mode_logo}}m-logo__image-light{{/if}}">
                    {{#if @root.custom.dark_mode_logo}}
                      <img src="{{@root.custom.dark_mode_logo}}" alt="{{@root.site.title}}" class="m-logo__image-dark">
                    {{/if}}
                  </a>
                </li>
                {{else}}
                <li class="only-desktop">
                  <a href="{{@root.site.url}}" class="m-site-name in-desktop-menu">
                    {{@root.site.title}}
                  </a>
                </li>
              {{/if}}
              {{#if @root.site.navigation}}
                {{navigation}}
              {{/if}}
              <li class="submenu-option js-submenu-option">
                <button class="m-icon-button in-menu-main more js-toggle-submenu" aria-label="Open submenu">
                  <span class="icon-more" aria-hidden="true"></span>
                </button>
                <div class="m-submenu js-submenu">
                  <div class="l-wrapper in-submenu">
                    <section class="m-recent-articles">
                      <h3 class="m-submenu-title in-recent-articles">Recent articles</h3>
                      {{#get "posts" limit="4" order="published_at desc" as |recent|}}
                        {{#if recent}}
                          <div class="swiper js-recent-slider">
                            <div class="swiper-wrapper">
                              {{#foreach recent}}
                                <div class="swiper-slide">
                                  <a href="/{{slug}}" class="m-recent-article">
                                    <div class="m-recent-article__picture {{#unless feature_image}}no-picture{{/unless}}">
                                      {{#if feature_image}}
                                        <img src="{{img_url feature_image size="s"}}" loading="lazy" alt="">
                                      {{else}}
                                        <img src="{{asset "images/no-image.png"}}" loading="lazy" alt="">
                                      {{/if}}
                                    </div>
                                    <h3 class="m-recent-article__title js-recent-article-title" title="{{title}}">
                                      {{title}}
                                    </h3>
                                    <span class="m-recent-article__date">{{date published_at timeago="true"}}</span>
                                  </a>
                                </div>
                              {{/foreach}}
                            </div>
                          </div>
                        {{else}}
                          <div class="m-not-found in-recent-articles">No recent articles found :(</div>
                        {{/if}}
                      {{/get}}
                    </section>
                    <section class="m-tags">
                      <h3 class="m-submenu-title">Tags</h3>
                      {{#get "tags" limit="10"}}
                        <ul>
                          {{#foreach tags}}
                            <li>
                              <a href="/{{slug}}">{{name}}</a>
                            </li>
                            {{else}}
                              <li class="m-not-found">No tags found :(</li>
                          {{/foreach}}
                        </ul>
                      {{/get}}
                    </section>
                  </div>
                </div>
              </li>
            </ul>
          </nav>
          <div class="m-nav__right">
            <a class="gh-head-button" href="/account">Account</a>
            <div class="cartanza-cart-container">
              <i class="fs-12 fa fa-shopping-bag cartanza-cart-icon" aria-hidden="true"></i>
              <span class="header-icons-noti cartanza-cart-total">3</span>
              <div class="cartanza-header-cart">
                <ul class="header-cart-wrapitem">
                  <li class="header-cart-item empty-cart">
                    <span class="header-cart-item-info">Empty Cart</span>
                  </li>
                </ul>
                <div class="header-cart-total">
                  Subtotal: $0.00
                </div>
                <div class="header-cart-buttons">
                  <div class="header-cart-wrapbtn">
                    <a href="/cart" class="header-cart-btn">
                      View Cart
                    </a>
                  </div>
                  <div class="header-cart-wrapbtn">
                    <a href="/checkout" class="header-cart-btn">
                      Checkout
                    </a>
                  </div>
                </div>
              </div>
            </div>
            <button class="m-icon-button in-menu-main {{#if @root.custom.enable_native_search}}js-open-search{{/if}}" {{#if @root.custom.enable_native_search}}data-ghost-search{{/if}} aria-label="Open search">
              <span class="icon-search" aria-hidden="true"></span>
            </button>
            <div class="m-toggle-darkmode js-tooltip" data-tippy-content="Toggle dark mode" tabindex="0">
              <label for="toggle-darkmode" class="sr-only">
                Toggle dark mode
              </label>
              <input id="toggle-darkmode" type="checkbox" class="js-toggle-darkmode">
              <div>
                <span class="icon-moon moon" aria-hidden="true"></span>
                <span class="icon-sunny sun" aria-hidden="true"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {{#if @root.site.secondary_navigation}}
    <div id="secondary-navigation-template" style="display: none;">
      {{navigation type="secondary"}}
    </div>
  {{/if}}
</header>
